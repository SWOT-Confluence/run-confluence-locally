START_INDEX=$(( ${OFFSET:-0} + SLURM_ARRAY_TASK_ID * ${INDEX_RANGE:-1} ))

{% set expanded_flag = "-e" if module.expanded else "" %}

apptainer run \
  --bind {{ mnt_dir }}/input:/data \
  {{ sif_dir }}/setfinder.sif \
  -c continent.json \
  {{ module.extra_args | default('') }} \
  {{ expanded_flag }} \
  -s {{ sword_version }} \
  -o /data \
  -n /data \
  -a MetroMan HiVDI SIC NeoBAM \
  -i ${START_INDEX}